{
  "name": "yaroc",
  "version": "0.1.0",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd ../napi --js index.js --dts index.d.ts",
    "build:debug": "napi build --platform --cargo-cwd ../napi --js index.js --dts index.d.ts",
    "prepublishOnly": "napi prepublish -t npm",
    "typecheck": "tsc --noEmit --target es2020 --moduleResolution node --skipLibCheck emulate_mqtt_native.ts",
    "emulate": "tsx emulate_mqtt_native.ts"
  },
  "napi": {
    "name": "index",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^20.14.9",
    "tsx": "^4.19.0",
    "typescript": "^5.5.2"
  },
  "optionalDependencies": {
    "yaroc-win32-x64-msvc": "0.1.0",
    "yaroc-linux-x64-gnu": "0.1.0",
    "yaroc-linux-arm64-gnu": "0.1.0"
  }
}
